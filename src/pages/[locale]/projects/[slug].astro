---
import ProjectPage, { getStaticPaths as getDefaultProjectPaths } from "../../projects/[slug].astro";
import { NON_DEFAULT_LOCALES } from "../../../lib/i18n";

export async function getStaticPaths() {
  const basePaths = await getDefaultProjectPaths();

  return NON_DEFAULT_LOCALES.flatMap((locale) =>
    basePaths.map((entry) => ({
      params: {
        ...entry.params,
        locale,
      },
      props: entry.props,
    })),
  );
}
---

<ProjectPage {...Astro.props} />
