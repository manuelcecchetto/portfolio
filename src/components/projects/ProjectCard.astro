---
import PaperCard from "../ui/PaperCard.astro";
import ImagePlaceholder from "../ui/ImagePlaceholder.astro";
import type { ProjectEntry } from "../../lib/content";
import { getCopy, localizePath, resolveLocale, toIntlLocale } from "../../lib/i18n";

export interface Props {
  project: ProjectEntry;
}

const { project } = Astro.props;
const locale = resolveLocale(Astro.currentLocale);
const t = getCopy(locale);

const href = localizePath(locale, `/projects/${project.data.slug}/`);
const tags = project.data.tags.length > 0 ? project.data.tags : ["case-study"];
const dateFormatter = new Intl.DateTimeFormat(toIntlLocale(locale), {
  month: "short",
  day: "numeric",
  year: "numeric",
});

const publishedLabel = dateFormatter.format(project.data.publishedAt);
const updatedLabel = project.data.updatedAt ? dateFormatter.format(project.data.updatedAt) : undefined;
---

<PaperCard as="article" variant={project.data.featured ? "outline" : "default"} padded="md" class="project-card">
  <a class="project-card__media" href={href}>
    {
      project.data.coverImage ? (
        <img
          class="project-card__image"
          src={project.data.coverImage}
          alt={`${t.projectCard.coverAltPrefix} ${project.data.title}`}
          loading="lazy"
          decoding="async"
        />
      ) : (
        <ImagePlaceholder label={`${project.data.title} Placeholder`} hint="Case study cover image" ratio="landscape" />
      )
    }
  </a>

  <div class="project-card__header">
    <h3 class="project-card__title">
      <a class="project-card__title-link" href={href}>{project.data.title}</a>
    </h3>
    <p class="project-card__summary">{project.data.summary}</p>
    <p class="project-card__meta">
      <span class="project-card__meta-item">{t.common.publishedPrefix} {publishedLabel}</span>
      {updatedLabel && <span class="project-card__meta-item">{t.common.updatedPrefix} {updatedLabel}</span>}
    </p>
  </div>

  <ul class="project-card__tags" role="list" aria-label={t.projectCard.tagsAria}>
    {tags.map((tag) => (
      <li>{tag}</li>
    ))}
  </ul>

  <div class="project-card__links">
    <a class="project-card__primary-link" href={href}>
      {t.projectCard.openDetails}
    </a>

    {project.data.repositoryUrl && (
      <a class="project-card__icon-link" href={project.data.repositoryUrl} target="_blank" rel="noreferrer" aria-label={t.projectCard.repository}>
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M12 1.5C6.2 1.5 1.5 6.2 1.5 12c0 4.66 3.02 8.6 7.2 9.99.53.1.72-.22.72-.5 0-.25-.01-1.08-.01-1.95-2.63.48-3.32-.64-3.53-1.23-.12-.3-.64-1.23-1.09-1.47-.37-.2-.9-.7-.01-.71.84-.01 1.44.77 1.64 1.09.96 1.61 2.49 1.15 3.1.88.1-.7.37-1.15.67-1.41-2.33-.27-4.77-1.16-4.77-5.17 0-1.14.4-2.08 1.08-2.81-.11-.27-.48-1.37.1-2.86 0 0 .88-.28 2.88 1.07a9.8 9.8 0 0 1 5.24 0c2-1.36 2.88-1.07 2.88-1.07.58 1.49.21 2.59.1 2.86.67.73 1.08 1.66 1.08 2.81 0 4.02-2.45 4.89-4.78 5.15.38.32.7.93.7 1.89 0 1.36-.01 2.45-.01 2.79 0 .27.19.6.72.5A10.51 10.51 0 0 0 22.5 12c0-5.8-4.7-10.5-10.5-10.5Z" />
        </svg>
        <span class="project-card__sr-only">{t.projectCard.repository}</span>
      </a>
    )}
    {project.data.demoUrl && (
      <a class="project-card__icon-link" href={project.data.demoUrl} target="_blank" rel="noreferrer" aria-label={t.projectCard.liveDemo}>
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M6.75 3A2.25 2.25 0 0 0 4.5 5.25v13.5A2.25 2.25 0 0 0 6.75 21h10.5a2.25 2.25 0 0 0 2.25-2.25V13.5a.75.75 0 0 0-1.5 0v5.25a.75.75 0 0 1-.75.75H6.75a.75.75 0 0 1-.75-.75V5.25a.75.75 0 0 1 .75-.75H12a.75.75 0 0 0 0-1.5H6.75Z" />
          <path d="M14.03 3.22a.75.75 0 0 0 0 1.5h4.19l-6.72 6.72a.75.75 0 1 0 1.06 1.06l6.72-6.72v4.19a.75.75 0 1 0 1.5 0V3.22h-6.75Z" />
        </svg>
        <span class="project-card__sr-only">{t.projectCard.liveDemo}</span>
      </a>
    )}
  </div>
</PaperCard>

<style>
  .project-card {
    --card-gap-section: var(--space-5);
    --card-gap-row: var(--space-3);

    display: grid;
    gap: var(--card-gap-section);
    height: 100%;
    align-content: start;
  }

  .project-card__media {
    display: block;
    text-decoration: none;
    aspect-ratio: 21 / 9;
    overflow: hidden;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-strong);
    background: hsl(0 0% 100% / 0.72);
  }

  .project-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .project-card__header {
    display: grid;
    gap: var(--card-gap-row);
  }

  .project-card__title {
    margin: 0;
  }

  .project-card__title-link {
    color: var(--color-text-strong);
    text-decoration: none;
    font-size: clamp(1.22rem, 0.7vw + 1rem, 1.52rem);
    letter-spacing: -0.01em;
    line-height: 1.15;
    display: inline-block;
  }

  .project-card__title-link:hover {
    color: var(--color-accent);
  }

  .project-card__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.74rem;
    font-family: var(--font-sans);
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--color-text-muted);
    margin-top: var(--space-1);
  }

  .project-card__meta-item {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-border-soft);
    background: hsl(0 0% 100% / 0.56);
    padding: 0.24rem 0.52rem;
    line-height: 1.2;
  }

  .project-card__summary {
    font-size: 1rem;
    line-height: 1.58;
    color: var(--color-text-body);
    max-width: 66ch;
  }

  .project-card__tags {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }

  .project-card__tags li {
    border-radius: var(--radius-pill);
    border: var(--line-soft);
    background: hsl(0 0% 100% / 0.78);
    padding: 0.26rem 0.58rem;
    font-size: 0.72rem;
    font-family: var(--font-sans);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }

  .project-card__links {
    margin-top: auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    font-size: 0.82rem;
    padding-top: var(--space-1);
    border-top: 1px solid hsl(214 18% 82% / 0.7);
  }

  .project-card__primary-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-pill);
    border: var(--line-strong);
    background: hsl(0 0% 100% / 0.8);
    padding: 0.52rem 0.82rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    color: var(--color-text-strong);
  }

  .project-card__primary-link:hover {
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }

  .project-card__icon-link {
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 999px;
    border: 1px solid var(--color-border-strong);
    background: hsl(0 0% 100% / 0.78);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-body);
    text-decoration: none;
  }

  .project-card__icon-link svg {
    width: 1.08rem;
    height: 1.08rem;
    fill: currentColor;
  }

  .project-card__icon-link:hover {
    color: var(--color-accent);
    background: var(--color-accent-soft);
    border-color: var(--color-accent);
  }

  .project-card__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 42rem) {
    .project-card {
      --card-gap-section: var(--space-4);
      --card-gap-row: var(--space-2);
    }

    .project-card__links {
      gap: var(--space-2);
      padding-top: 0;
      border-top: 0;
    }
  }
</style>
