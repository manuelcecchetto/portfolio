---
export interface Props {
  as?: "article" | "section" | "div" | "aside";
  variant?: "default" | "outline" | "glass";
  padded?: "sm" | "md" | "lg";
  lift?: boolean;
  class?: string;
}

const {
  as: Tag = "article",
  variant = "default",
  padded = "md",
  lift = true,
  class: className = ""
} = Astro.props;
---

<Tag
  class:list={["paper-card", `paper-card--${variant}`, `paper-card--pad-${padded}`, className]}
  data-lift={lift ? "true" : "false"}
>
  <slot />
</Tag>
