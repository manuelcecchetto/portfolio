---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MotionReveal from "../../components/ui/MotionReveal.astro";
import StaggerGroup from "../../components/ui/StaggerGroup.astro";
import PaperCard from "../../components/ui/PaperCard.astro";
import ProjectCard from "../../components/projects/ProjectCard.astro";
import { getLocalizedProjects } from "../../lib/content";
import { getCopy, resolveLocale } from "../../lib/i18n";

const locale = resolveLocale(Astro.currentLocale);
const projects = await getLocalizedProjects(locale);
const featuredCount = projects.filter((project) => project.data.featured).length;
const t = getCopy(locale);
---

<BaseLayout
  title={t.seo.projectsTitle}
  description={t.seo.projectsDescription}
>
  <MotionReveal as="section" kind="soft-zoom" class="page-hero projects-hero" slot="hero">
    <span class="eyebrow">{t.projectsPage.eyebrow}</span>
    <h1>{t.projectsPage.heroTitle}</h1>
    <p>{t.projectsPage.heroText}</p>

    <div class="projects-hero__meta" role="list" aria-label={t.projectsPage.archiveSummaryAria}>
      <span class="pill" role="listitem">{projects.length} {t.projectsPage.publishedLabel}</span>
      <span class="pill" role="listitem">{featuredCount} {t.projectsPage.featuredLabel}</span>
      <span class="pill" role="listitem">{t.projectsPage.narrativeLabel}</span>
    </div>
  </MotionReveal>

  {
    projects.length === 0 ? (
      <PaperCard as="section" variant="outline" padded="md" lift={false}>
        <p class="text-muted">{t.projectsPage.emptyState}</p>
      </PaperCard>
    ) : (
      <section class="stack projects-list" aria-labelledby="projects-list-title">
        <MotionReveal as="div" kind="slide-in" delay={100}>
          <h2 id="projects-list-title">{t.projectsPage.listTitle}</h2>
          <p class="text-muted">{t.projectsPage.listText}</p>
        </MotionReveal>

        <StaggerGroup as="ul" class="projects-list__grid" step={80}>
          {projects.map((project) => (
            <li>
              <ProjectCard project={project} />
            </li>
          ))}
        </StaggerGroup>
      </section>
    )
  }
</BaseLayout>

<style>
  .projects-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .projects-list {
    margin-top: var(--space-4);
  }

  .projects-list__grid {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--space-4);
    grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr));
  }
</style>
