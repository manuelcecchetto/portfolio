---
import PaperCard from "../ui/PaperCard.astro";
import ImagePlaceholder from "../ui/ImagePlaceholder.astro";
import type { BlogEntry } from "../../lib/content";
import { getCopy, localizePath, resolveLocale, toIntlLocale } from "../../lib/i18n";

export interface Props {
  post: BlogEntry;
}

const { post } = Astro.props;
const locale = resolveLocale(Astro.currentLocale);
const t = getCopy(locale);
const href = localizePath(locale, `/blog/${post.data.slug}/`);
const tags = post.data.tags;
const dateFormatter = new Intl.DateTimeFormat(toIntlLocale(locale), {
  month: "short",
  day: "numeric",
  year: "numeric",
});

const publishedLabel = dateFormatter.format(post.data.publishedAt);
const updatedLabel = post.data.updatedAt ? dateFormatter.format(post.data.updatedAt) : undefined;
---

<PaperCard as="article" variant={post.data.draft ? "glass" : "default"} padded="md" class="blog-card">
  <a class="blog-card__media" href={href}>
    {
      post.data.coverImage ? (
        <img
          class="blog-card__image"
          src={post.data.coverImage}
          alt={`${t.blogCard.coverAltPrefix} ${post.data.title}`}
          loading="lazy"
          decoding="async"
        />
      ) : (
        <ImagePlaceholder label={`${post.data.title} Placeholder`} hint="Article cover image" ratio="landscape" />
      )
    }
  </a>

  <div class="blog-card__header">
    <h2 class="blog-card__title">
      <a class="blog-card__title-link" href={href}>{post.data.title}</a>
    </h2>
    <p class="blog-card__summary">{post.data.summary}</p>
    <p class="blog-card__meta">
      <span class="blog-card__meta-item">{t.common.publishedPrefix} {publishedLabel}</span>
      {updatedLabel && <span class="blog-card__meta-item">{t.common.updatedPrefix} {updatedLabel}</span>}
      {post.data.readingTimeMinutes && <span class="blog-card__meta-item">{post.data.readingTimeMinutes} {t.common.minReadSuffix}</span>}
      {post.data.draft && <span class="blog-card__meta-item blog-card__draft">{t.blogCard.draft}</span>}
    </p>
  </div>

  {
    tags.length > 0 && (
      <ul class="blog-card__tags" role="list" aria-label={`${t.blogCard.tagsForPrefix} ${post.data.title}`}>
        {tags.map((tag) => (
          <li>
            <a href={localizePath(locale, `/blog/tags/${encodeURIComponent(tag)}/`)}>{tag}</a>
          </li>
        ))}
      </ul>
    )
  }

  <div class="blog-card__actions">
    <a class="blog-card__link" href={href}>
      {t.blogCard.readArticle}
    </a>
  </div>
</PaperCard>

<style>
  .blog-card {
    --card-gap-section: var(--space-5);
    --card-gap-row: var(--space-3);

    display: grid;
    gap: var(--card-gap-section);
    height: 100%;
  }

  .blog-card__media {
    display: block;
    text-decoration: none;
    aspect-ratio: 21 / 9;
    overflow: hidden;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-strong);
    background: hsl(0 0% 100% / 0.72);
  }

  .blog-card__header {
    display: grid;
    gap: var(--card-gap-row);
  }

  .blog-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .blog-card__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.74rem;
    font-family: var(--font-sans);
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--color-text-muted);
    margin-top: var(--space-1);
  }

  .blog-card__meta-item {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-border-soft);
    background: hsl(0 0% 100% / 0.56);
    padding: 0.24rem 0.52rem;
    line-height: 1.2;
  }

  .blog-card__draft {
    border-color: var(--color-border-strong);
    background: var(--color-accent-soft);
    color: var(--color-text-strong);
  }

  .blog-card__title {
    margin: 0;
  }

  .blog-card__title-link {
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-family: var(--font-display);
    font-size: clamp(1rem, 0.55vw + 0.9rem, 1.2rem);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-text-strong);
    text-decoration: none;
  }

  .blog-card__title-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .blog-card__summary {
    max-width: 66ch;
  }

  .blog-card__tags {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }

  .blog-card__tags li a {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-pill);
    border: var(--line-soft);
    background: hsl(0 0% 100% / 0.78);
    color: var(--color-text-muted);
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.3rem 0.58rem;
  }

  .blog-card__tags li a:hover {
    color: var(--color-text-strong);
    border-color: var(--color-border-strong);
  }

  .blog-card__actions {
    margin-top: auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    font-size: 0.82rem;
    padding-top: var(--space-1);
    border-top: 1px solid hsl(214 18% 82% / 0.7);
  }

  .blog-card__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-pill);
    border: var(--line-strong);
    background: hsl(0 0% 100% / 0.8);
    padding: 0.52rem 0.82rem;
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-strong);
  }

  .blog-card__link:hover {
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }

  @media (max-width: 42rem) {
    .blog-card {
      --card-gap-section: var(--space-4);
      --card-gap-row: var(--space-2);
    }

    .blog-card__actions {
      gap: var(--space-2);
      padding-top: 0;
      border-top: 0;
    }
  }
</style>
